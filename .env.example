# Database
DATABASE_URL="your-database-url"

# NextAuth
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# Message Encryption
MESSAGE_ENCRYPTION_KEY="your-32-character-secret-key!!"

# Cloudflare R2 (for file uploads)
CLOUDFLARE_R2_ACCESS_KEY_ID="your-access-key"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your-secret-key"
CLOUDFLARE_R2_BUCKET_NAME="projectify"
CLOUDFLARE_R2_ENDPOINT="https://xxx.r2.cloudflarestorage.com"
CLOUDFLARE_R2_PUBLIC_URL="https://your-public-url.com"

# Cohere AI API (for similarity checking)
cohere_api_key="your-cohere-api-key"
COHERE_MODEL="command-r-08-2024"

# Qdrant Vector Database (for similarity checking)
clusterurl="https://your-cluster.qdrant.io"
QDRANT_API_KEY="your-qdrant-api-key"

# Socket.IO Configuration
NEXT_PUBLIC_SOCKET_URL=""  # Leave empty for same-origin, or set to your socket server URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Redis (Optional - for horizontal scaling of WebSockets)
REDIS_URL=""  # e.g., "redis://localhost:6379" or "redis://username:password@host:port"

# Resend Email API (for password reset emails)
RESEND_API_KEY="your-resend-api-key"
