# Database
DATABASE_URL="your-database-url"

# NextAuth
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Message Encryption
MESSAGE_ENCRYPTION_KEY="your-32-character-secret-key!!"

# Cloudflare R2 (for file uploads)
R2_ACCOUNT_ID="your-account-id"
R2_BUCKET_NAME="your-bucket-name"
R2_API_TOKEN="your-api-token"
R2_PUBLIC_URL="https://your-r2-public-url.r2.dev"

# Cohere AI API (for similarity checking)
cohere_api_key="your-cohere-api-key"
COHERE_MODEL="command-r-08-2024"

# Pinecone Vector Database (for similarity checking)
PINECONE_API_KEY="your-pinecone-api-key"
PINECONE_INDEX_NAME="project-embeddings"

# Socket.IO Configuration
NEXT_PUBLIC_SOCKET_URL=""

# Redis (Optional - for horizontal scaling of WebSockets)
REDIS_URL=""

# Brevo (formerly Sendinblue) — HTTP API email, works on Railway (no SMTP port blocking)
# Sign up free at https://app.brevo.com → Settings → SMTP & API → API Keys → Create API Key
# Free tier: 300 emails/day, no custom domain required
# Add your sender email in Brevo → Senders & IP → Senders → Add a sender
BREVO_API_KEY="your-brevo-api-key-here"
BREVO_SENDER_EMAIL="youremail@gmail.com"

# App URL (used in email links)
APP_URL="https://projectify.up.railway.app"
