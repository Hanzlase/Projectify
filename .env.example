# Database
DATABASE_URL="your-database-url"

# NextAuth
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Message Encryption
MESSAGE_ENCRYPTION_KEY="your-32-character-secret-key!!"

# Cloudflare R2 (for file uploads)
R2_ACCOUNT_ID="your-account-id"
R2_BUCKET_NAME="your-bucket-name"
R2_API_TOKEN="your-api-token"
R2_PUBLIC_URL="https://your-r2-public-url.r2.dev"

# Cohere AI API (for similarity checking)
cohere_api_key="your-cohere-api-key"
COHERE_MODEL="command-r-08-2024"

# Pinecone Vector Database (for similarity checking)
PINECONE_API_KEY="your-pinecone-api-key"
PINECONE_INDEX_NAME="project-embeddings"

# Socket.IO Configuration
NEXT_PUBLIC_SOCKET_URL=""

# Redis (Optional - for horizontal scaling of WebSockets)
REDIS_URL=""

# Gmail SMTP (for password reset emails and meeting notifications)
# Use a Gmail App Password — NOT your regular Gmail password.
# Setup: myaccount.google.com → Security → 2-Step Verification → App Passwords
# Create an app password for "Mail" → "Other (Projectify)" → copy the 16-char code
EMAIL_USER="yourgmail@gmail.com"
EMAIL_PASS="xxxx xxxx xxxx xxxx"

# App URL (used in email links)
APP_URL="https://projectify.up.railway.app"
