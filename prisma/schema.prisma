generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  userId              Int                  @id @default(autoincrement()) @map("user_id")
  name                String               @db.VarChar(255)
  email               String               @unique @db.VarChar(255)
  passwordHash        String               @map("password_hash") @db.VarChar(255)
  role                UserRole
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  profileImage        String?              @map("profile_image") @db.VarChar(500)
  status              UserStatus           @default(ACTIVE)
  admin               Admin?
  coordinator         FYPCoordinator?
  supervisor          FYPSupervisor?
  passwordResetTokens PasswordResetToken[]
  student             Student?

  @@map("users")
}

model Admin {
  adminId   Int      @id @default(autoincrement()) @map("admin_id")
  userId    Int      @unique @map("user_id")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("admins")
}

model Campus {
  campusId        Int              @id @default(autoincrement()) @map("campus_id")
  name            String           @db.VarChar(255)
  location        String?          @db.VarChar(255)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  maxCoordinators Int              @default(5) @map("max_coordinators")
  activeSemester  Semester         @default(FALL) @map("active_semester")
  coordinators    FYPCoordinator[]
  supervisors     FYPSupervisor[]
  students        Student[]

  @@map("campuses")
}

model FYPCoordinator {
  coordinatorId Int      @id @default(autoincrement()) @map("coordinator_id")
  userId        Int      @unique @map("user_id")
  campusId      Int      @map("campus_id")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  campus        Campus   @relation(fields: [campusId], references: [campusId])
  user          User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("fyp_coordinators")
}

model FYPSupervisor {
  supervisorId   Int      @id @default(autoincrement()) @map("supervisor_id")
  userId         Int      @unique @map("user_id")
  campusId       Int      @map("campus_id")
  description    String?
  specialization String?  @db.VarChar(255)
  maxGroups      Int      @default(7) @map("max_groups")
  totalGroups    Int      @default(0) @map("total_groups")
  revertedBy     Int?     @map("reverted_by")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  achievements   String?
  domains        String?
  skills         String?
  campus         Campus   @relation(fields: [campusId], references: [campusId])
  user           User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([campusId])
  @@map("fyp_supervisors")
}

model Group {
  groupId          Int               @id @default(autoincrement()) @map("group_id")
  groupName        String?           @map("group_name") @db.VarChar(255)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  createdById      Int               @map("created_by_id")
  supervisorId     Int?              @map("supervisor_id")
  isFull           Boolean           @default(false) @map("is_full")
  projectId        Int?              @unique @map("project_id")
  groupImage       String?           @map("group_image")
  cohort           Cohort            @default(REGULAR)
  fypPhase         FypPhase          @default(FYP_1) @map("fyp_phase")
  groupChats       GroupChat[]
  groupInvitations GroupInvitation[]
  meetings         Meeting[]
  students         Student[]

  @@index([supervisorId])
  @@index([createdById])
  @@map("groups")
}

model GroupInvitation {
  id          Int                   @id @default(autoincrement())
  groupId     Int                   @map("group_id")
  inviterId   Int                   @map("inviter_id")
  inviteeId   Int                   @map("invitee_id")
  inviteeRole String                @map("invitee_role") @db.VarChar(20)
  status      GroupInvitationStatus @default(pending)
  message     String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  group       Group                 @relation(fields: [groupId], references: [groupId], onDelete: Cascade)

  @@unique([groupId, inviteeId])
  @@index([inviteeId, status])
  @@index([inviterId])
  @@map("group_invitations")
}

model IndustrialProject {
  id              Int                        @id @default(autoincrement())
  title           String                     @db.VarChar(255)
  description     String
  status          IndustrialProjectStatus    @default(available)
  uploadedById    Int                        @map("uploaded_by_id")
  campusId        Int                        @map("campus_id")
  assignedGroupId Int?                       @unique @map("assigned_group_id")
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  features        String?
  techStack       String?                    @map("tech_stack")
  thumbnailUrl    String?                    @map("thumbnail_url") @db.VarChar(500)
  fypPhase        FypPhase                   @default(FYP_1) @map("fyp_phase")
  requests        IndustrialProjectRequest[]

  @@index([campusId])
  @@index([status])
  @@index([uploadedById])
  @@map("industrial_projects")
}

model IndustrialProjectRequest {
  id                  Int                            @id @default(autoincrement())
  industrialProjectId Int                            @map("industrial_project_id")
  requesterId         Int                            @map("requester_id")
  requesterRole       String                         @map("requester_role") @db.VarChar(20)
  groupId             Int?                           @map("group_id")
  message             String?
  status              IndustrialProjectRequestStatus @default(pending)
  respondedAt         DateTime?                      @map("responded_at")
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt
  industrialProject   IndustrialProject              @relation(fields: [industrialProjectId], references: [id], onDelete: Cascade)

  @@unique([industrialProjectId, requesterId])
  @@index([requesterId])
  @@index([status])
  @@map("industrial_project_requests")
}

model GroupChat {
  id             Int      @id @default(autoincrement())
  groupId        Int      @map("group_id")
  conversationId Int      @unique @map("conversation_id")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  group          Group    @relation(fields: [groupId], references: [groupId], onDelete: Cascade)

  @@map("group_chats")
}

model PinnedConversation {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  conversationId Int      @map("conversation_id")
  pinnedAt       DateTime @default(now())

  @@unique([userId, conversationId])
  @@map("pinned_conversations")
}

model Student {
  studentId           Int          @id @default(autoincrement()) @map("student_id")
  userId              Int          @unique @map("user_id")
  rollNumber          String       @unique @map("roll_number") @db.VarChar(50)
  batch               String?      @db.VarChar(20)
  campusId            Int          @map("campus_id")
  groupId             Int?         @map("group_id")
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  bio                 String?
  github              String?      @db.VarChar(255)
  gpa                 Float?
  interests           String?
  linkedin            String?      @db.VarChar(255)
  skills              String?
  isGroupAdmin        Boolean      @default(false) @map("is_group_admin")
  cohort              Cohort       @default(REGULAR)
  receivedInvitations Invitation[] @relation("ReceivedInvitations")
  sentInvitations     Invitation[] @relation("SentInvitations")
  campus              Campus       @relation(fields: [campusId], references: [campusId])
  group               Group?       @relation(fields: [groupId], references: [groupId])
  user                User         @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([campusId])
  @@index([groupId])
  @@index([campusId, groupId])
  @@map("students")
}

model Invitation {
  invitationId Int              @id @default(autoincrement()) @map("invitation_id")
  senderId     Int              @map("sender_id")
  receiverId   Int              @map("receiver_id")
  message      String?
  status       InvitationStatus @default(pending)
  type         InvitationType   @default(group_invite)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  receiver     Student          @relation("ReceivedInvitations", fields: [receiverId], references: [studentId], onDelete: Cascade)
  sender       Student          @relation("SentInvitations", fields: [senderId], references: [studentId], onDelete: Cascade)

  @@unique([senderId, receiverId, type])
  @@index([receiverId, status])
  @@index([senderId])
  @@map("invitations")
}

model Notification {
  notificationId Int                     @id @default(autoincrement()) @map("notification_id")
  title          String                  @db.VarChar(255)
  message        String
  type           NotificationType        @default(general)
  targetType     NotificationTarget      @map("target_type")
  createdById    Int?                    @map("created_by_id")
  campusId       Int                     @map("campus_id")
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  targetCohort   Cohort?                 @map("target_cohort")
  recipients     NotificationRecipient[]

  @@index([campusId])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationRecipient {
  id             Int          @id @default(autoincrement())
  notificationId Int          @map("notification_id")
  userId         Int          @map("user_id")
  isRead         Boolean      @default(false) @map("is_read")
  readAt         DateTime?    @map("read_at")
  createdAt      DateTime     @default(now())
  notification   Notification @relation(fields: [notificationId], references: [notificationId], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notification_recipients")
}

model Conversation {
  conversationId Int                       @id @default(autoincrement()) @map("conversation_id")
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  participants   ConversationParticipant[]
  messages       Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             Int          @id @default(autoincrement())
  conversationId Int          @map("conversation_id")
  userId         Int          @map("user_id")
  lastReadAt     DateTime?    @map("last_read_at")
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [conversationId], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  messageId      Int          @id @default(autoincrement()) @map("message_id")
  conversationId Int          @map("conversation_id")
  senderId       Int          @map("sender_id")
  content        String
  isRead         Boolean      @default(false) @map("is_read")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  attachmentName String?      @map("attachment_name") @db.VarChar(255)
  attachmentType String?      @map("attachment_type") @db.VarChar(50)
  attachmentUrl  String?      @map("attachment_url") @db.VarChar(500)
  conversation   Conversation @relation(fields: [conversationId], references: [conversationId], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([conversationId, isRead])
  @@map("messages")
}

model Project {
  projectId         Int               @id @default(autoincrement()) @map("project_id")
  title             String            @db.VarChar(255)
  description       String
  category          String?           @db.VarChar(100)
  status            ProjectStatus     @default(in_progress)
  visibility        ProjectVisibility @default(private)
  thumbnailUrl      String?           @map("thumbnail_url") @db.VarChar(500)
  documentUrl       String?           @map("document_url") @db.VarChar(500)
  repositoryUrl     String?           @map("repository_url") @db.VarChar(500)
  demoUrl           String?           @map("demo_url") @db.VarChar(500)
  createdById       Int               @map("created_by_id")
  groupId           Int?              @map("group_id")
  campusId          Int               @map("campus_id")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  abstractText      String?           @map("abstract_text")
  documentName      String?           @map("document_name") @db.VarChar(255)
  embeddingId       String?           @map("embedding_id") @db.VarChar(100)
  isUnique          Boolean           @default(false) @map("is_unique")
  similarityScore   Float?            @map("similarity_score")
  feasibilityReport Json?             @map("feasibility_report")

  @@index([campusId])
  @@index([campusId, visibility])
  @@index([groupId])
  @@index([createdById])
  @@index([status])
  @@map("projects")
}

model ProjectPermissionRequest {
  id          Int                     @id @default(autoincrement())
  projectId   Int                     @map("project_id")
  requesterId Int                     @map("requester_id")
  ownerId     Int                     @map("owner_id")
  groupId     Int?                    @map("group_id")
  message     String?
  status      ProjectPermissionStatus @default(pending)
  respondedAt DateTime?               @map("responded_at")
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@unique([projectId, requesterId])
  @@map("project_permission_requests")
}

model Meeting {
  meetingId     Int                    @id @default(autoincrement()) @map("meeting_id")
  groupId       Int                    @map("group_id")
  title         String                 @db.VarChar(255)
  description   String?
  meetingLink   String?                @map("meeting_link") @db.VarChar(500)
  scheduledAt   DateTime               @map("scheduled_at")
  duration      Int                    @default(60)
  status        MeetingStatus          @default(scheduled)
  createdById   Int                    @map("created_by_id")
  createdByRole String                 @map("created_by_role") @db.VarChar(20)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  reminders     MeetingEmailReminder[]
  group         Group                  @relation(fields: [groupId], references: [groupId], onDelete: Cascade)

  @@index([groupId])
  @@index([scheduledAt])
  @@map("meetings")
}

model MeetingEmailReminder {
  id           Int       @id @default(autoincrement())
  meetingId    Int       @map("meeting_id")
  reminderType String    @map("reminder_type") @db.VarChar(20)
  sendAt       DateTime  @map("send_at")
  sent         Boolean   @default(false)
  sentAt       DateTime? @map("sent_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  meeting      Meeting   @relation(fields: [meetingId], references: [meetingId], onDelete: Cascade)

  @@index([sent, sendAt])
  @@index([meetingId])
  @@map("meeting_email_reminders")
}

model ProjectTask {
  taskId      Int          @id @default(autoincrement()) @map("task_id")
  groupId     Int          @map("group_id")
  parentId    Int?         @map("parent_id")
  title       String       @db.VarChar(255)
  description String?
  assignedTo  Int?         @map("assigned_to")
  status      TaskStatus   @default(pending)
  priority    TaskPriority @default(medium)
  dueDate     DateTime?    @map("due_date")
  completedAt DateTime?    @map("completed_at")
  createdById Int          @map("created_by_id")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([groupId])
  @@index([parentId])
  @@index([assignedTo])
  @@index([status])
  @@map("project_tasks")
}

model PhaseAttachment {
  attachmentId Int                @id @default(autoincrement()) @map("attachment_id")
  phaseId      Int                @map("phase_id")
  fileName     String             @map("file_name") @db.VarChar(255)
  fileUrl      String             @map("file_url") @db.VarChar(500)
  fileSize     Int?               @map("file_size")
  fileType     String?            @map("file_type") @db.VarChar(100)
  createdAt    DateTime           @default(now())
  phase        FypEvaluationPhase @relation(fields: [phaseId], references: [phaseId], onDelete: Cascade)

  @@index([phaseId])
  @@map("phase_attachments")
}

model EvaluationSubmission {
  submissionId         Int                    @id @default(autoincrement()) @map("submission_id")
  groupId              Int                    @map("group_id")
  submittedById        Int                    @map("submitted_by_id")
  content              String?
  status               SubmissionStatus       @default(pending)
  obtainedMarks        Int?                   @map("obtained_marks")
  feedback             String?
  gradedById           Int?                   @map("graded_by_id")
  gradedAt             DateTime?              @map("graded_at")
  submittedAt          DateTime               @default(now()) @map("submitted_at")
  updatedAt            DateTime               @updatedAt
  panelFeedback        String?                @map("panel_feedback")
  panelScore           Int?                   @map("panel_score")
  panelScoredAt        DateTime?              @map("panel_scored_at")
  panelScoredById      Int?                   @map("panel_scored_by_id")
  supervisorFeedback   String?                @map("supervisor_feedback")
  supervisorScore      Int?                   @map("supervisor_score")
  supervisorScoredAt   DateTime?              @map("supervisor_scored_at")
  supervisorScoredById Int?                   @map("supervisor_scored_by_id")
  phaseId              Int                    @map("phase_id")
  panelMemberScores    Json?                  @map("panel_member_scores")
  phase                FypEvaluationPhase     @relation(fields: [phaseId], references: [phaseId], onDelete: Cascade)
  attachments          SubmissionAttachment[]
  comments             SubmissionComment[]

  @@unique([phaseId, groupId])
  @@index([phaseId])
  @@index([groupId])
  @@index([submittedById])
  @@index([status])
  @@map("evaluation_submissions")
}

model SubmissionComment {
  commentId    Int                  @id @default(autoincrement()) @map("comment_id")
  submissionId Int                  @map("submission_id")
  userId       Int                  @map("user_id")
  content      String
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  submission   EvaluationSubmission @relation(fields: [submissionId], references: [submissionId], onDelete: Cascade)

  @@index([submissionId])
  @@index([userId])
  @@map("submission_comments")
}

model SubmissionAttachment {
  attachmentId Int                  @id @default(autoincrement()) @map("attachment_id")
  submissionId Int                  @map("submission_id")
  fileName     String               @map("file_name") @db.VarChar(255)
  fileUrl      String               @map("file_url") @db.VarChar(500)
  fileSize     Int?                 @map("file_size")
  fileType     String?              @map("file_type") @db.VarChar(100)
  uploadedAt   DateTime             @default(now()) @map("uploaded_at")
  submission   EvaluationSubmission @relation(fields: [submissionId], references: [submissionId], onDelete: Cascade)

  @@index([submissionId])
  @@map("submission_attachments")
}

model EvaluationPanel {
  panelId          Int                    @id @default(autoincrement()) @map("panel_id")
  name             String                 @db.VarChar(255)
  description      String?
  evaluationType   String?                @map("evaluation_type") @db.VarChar(100)
  minSupervisors   Int                    @default(2) @map("min_supervisors")
  maxSupervisors   Int                    @default(4) @map("max_supervisors")
  scheduledDate    DateTime?              @map("scheduled_date")
  status           EvaluationPanelStatus  @default(draft)
  campusId         Int                    @map("campus_id")
  createdById      Int                    @map("created_by_id")
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  cohort           Cohort                 @default(REGULAR)
  fypPhase         FypPhase               @default(FYP_1) @map("fyp_phase")
  phaseId          Int?                   @map("phase_id")
  phase            FypEvaluationPhase?    @relation(fields: [phaseId], references: [phaseId])
  groupAssignments GroupPanelAssignment[]
  panelMembers     PanelMember[]

  @@index([campusId])
  @@index([createdById])
  @@index([status])
  @@index([scheduledDate])
  @@index([phaseId])
  @@map("evaluation_panels")
}

model FypEvaluationPhase {
  phaseId      Int                    @id @default(autoincrement()) @map("phase_id")
  name         String                 @db.VarChar(255)
  description  String?
  weightage    Float                  @default(0)
  fypPhase     FypPhase               @map("fyp_phase")
  cohort       Cohort                 @default(REGULAR)
  campusId     Int                    @map("campus_id")
  isActive     Boolean                @default(false) @map("is_active")
  orderIndex   Int                    @default(0) @map("order_index")
  createdById  Int                    @map("created_by_id")
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  deadline     DateTime?              @map("deadline")
  instructions String?
  status       EvaluationStatus       @default(draft)
  totalMarks   Int                    @default(100) @map("total_marks")
  panels       EvaluationPanel[]
  submissions  EvaluationSubmission[]
  attachments  PhaseAttachment[]

  @@index([campusId, fypPhase, cohort])
  @@index([campusId, isActive])
  @@map("fyp_evaluation_phases")
}

model PanelMember {
  id           Int             @id @default(autoincrement())
  panelId      Int             @map("panel_id")
  supervisorId Int             @map("supervisor_id")
  role         PanelMemberRole @default(member)
  addedAt      DateTime        @default(now()) @map("added_at")
  panel        EvaluationPanel @relation(fields: [panelId], references: [panelId], onDelete: Cascade)

  @@unique([panelId, supervisorId])
  @@index([supervisorId])
  @@map("panel_members")
}

model GroupPanelAssignment {
  id             Int             @id @default(autoincrement())
  panelId        Int             @map("panel_id")
  groupId        Int             @map("group_id")
  assignedAt     DateTime        @default(now()) @map("assigned_at")
  evaluationDate DateTime?       @map("evaluation_date")
  timeSlot       String?         @map("time_slot") @db.VarChar(50)
  venue          String?         @db.VarChar(255)
  remarks        String?
  score          Int?
  scoredAt       DateTime?       @map("scored_at")
  scoredById     Int?            @map("scored_by_id")
  panel          EvaluationPanel @relation(fields: [panelId], references: [panelId], onDelete: Cascade)
  comments       PanelComment[]

  @@unique([panelId, groupId])
  @@index([groupId])
  @@index([evaluationDate])
  @@map("group_panel_assignments")
}

model PanelComment {
  commentId    Int                  @id @default(autoincrement()) @map("comment_id")
  assignmentId Int                  @map("assignment_id")
  userId       Int                  @map("user_id")
  content      String
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  assignment   GroupPanelAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
  @@index([userId])
  @@map("panel_comments")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

model ResourceRequest {
  id                    Int                   @id @default(autoincrement())
  groupId               Int                   @map("group_id")
  title                 String                @db.VarChar(255)
  description           String?
  resourceType          ResourceType          @default(hardware) @map("resource_type")
  items                 String
  justification         String?
  status                ResourceRequestStatus @default(pending)
  supervisorId          Int?                  @map("supervisor_id")
  supervisorNote        String?               @map("supervisor_note")
  supervisorAction      String?               @map("supervisor_action") @db.VarChar(20)
  supervisorReviewedAt  DateTime?             @map("supervisor_reviewed_at")
  coordinatorId         Int?                  @map("coordinator_id")
  coordinatorNote       String?               @map("coordinator_note")
  meetingDate           DateTime?             @map("meeting_date")
  meetingTime           String?               @map("meeting_time") @db.VarChar(50)
  meetingLink           String?               @map("meeting_link") @db.VarChar(500)
  meetingVenue          String?               @map("meeting_venue") @db.VarChar(255)
  meetingType           String?               @map("meeting_type") @db.VarChar(20)
  coordinatorReviewedAt DateTime?             @map("coordinator_reviewed_at")
  createdById           Int                   @map("created_by_id")
  campusId              Int                   @map("campus_id")
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([groupId])
  @@index([campusId])
  @@index([status])
  @@index([supervisorId])
  @@map("resource_requests")
}

enum GroupInvitationStatus {
  pending
  accepted
  rejected
  cancelled
}

enum IndustrialProjectStatus {
  available
  booked
  completed
}

enum IndustrialProjectRequestStatus {
  pending
  approved
  rejected
}

enum InvitationStatus {
  pending
  accepted
  rejected
  cancelled
}

enum InvitationType {
  group_invite
  collaboration
}

enum NotificationType {
