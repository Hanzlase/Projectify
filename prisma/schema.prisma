generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model campuses {
  campus_id        Int                @id @default(autoincrement())
  name             String             @db.VarChar(255)
  location         String?            @db.VarChar(255)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  fyp_coordinators fyp_coordinators[]
  fyp_supervisors  fyp_supervisors[]
  students         students[]
}

model conversation_participants {
  id              Int           @id @default(autoincrement())
  conversation_id Int
  user_id         Int
  last_read_at    DateTime?
  createdAt       DateTime      @default(now())
  conversations   conversations @relation(fields: [conversation_id], references: [conversation_id], onDelete: Cascade)

  @@unique([conversation_id, user_id])
  @@index([user_id])
}

model conversations {
  conversation_id           Int                         @id @default(autoincrement())
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime
  conversation_participants conversation_participants[]
  messages                  messages[]
}

model fyp_coordinators {
  coordinator_id Int      @id @default(autoincrement())
  user_id        Int      @unique
  campus_id      Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  campuses       campuses @relation(fields: [campus_id], references: [campus_id])
  users          users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

model fyp_supervisors {
  supervisor_id  Int      @id @default(autoincrement())
  user_id        Int      @unique
  campus_id      Int
  description    String?
  specialization String?  @db.VarChar(255)
  max_groups     Int      @default(7)
  total_groups   Int      @default(0)
  reverted_by    Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  achievements   String?
  domains        String?
  skills         String?
  campuses       campuses @relation(fields: [campus_id], references: [campus_id])
  users          users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([campus_id])
}

model group_chats {
  id              Int      @id @default(autoincrement())
  group_id        Int
  conversation_id Int      @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  groups          groups   @relation(fields: [group_id], references: [group_id], onDelete: Cascade)
}

model group_invitations {
  id           Int                   @id @default(autoincrement())
  group_id     Int
  inviter_id   Int
  invitee_id   Int
  invitee_role String                @db.VarChar(20)
  status       GroupInvitationStatus @default(pending)
  message      String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime
  groups       groups                @relation(fields: [group_id], references: [group_id], onDelete: Cascade)

  @@unique([group_id, invitee_id])
  @@index([invitee_id, status])
  @@index([inviter_id])
}

model groups {
  group_id          Int                 @id @default(autoincrement())
  group_name        String?             @db.VarChar(255)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  created_by_id     Int
  supervisor_id     Int?
  is_full           Boolean             @default(false)
  project_id        Int?                @unique
  group_image       String?
  group_chats       group_chats[]
  group_invitations group_invitations[]
  students          students[]

  @@index([created_by_id])
  @@index([supervisor_id])
}

model industrial_project_requests {
  id                    Int                            @id @default(autoincrement())
  industrial_project_id Int
  requester_id          Int
  requester_role        String                         @db.VarChar(20)
  group_id              Int?
  message               String?
  status                IndustrialProjectRequestStatus @default(pending)
  responded_at          DateTime?
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime
  industrial_projects   industrial_projects            @relation(fields: [industrial_project_id], references: [id], onDelete: Cascade)

  @@unique([industrial_project_id, requester_id])
  @@index([requester_id])
  @@index([status])
}

model industrial_projects {
  id                          Int                           @id @default(autoincrement())
  title                       String                        @db.VarChar(255)
  description                 String
  status                      IndustrialProjectStatus       @default(available)
  uploaded_by_id              Int
  campus_id                   Int
  assigned_group_id           Int?                          @unique
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime
  features                    String?
  tech_stack                  String?
  thumbnail_url               String?                       @db.VarChar(500)
  industrial_project_requests industrial_project_requests[]

  @@index([campus_id])
  @@index([status])
  @@index([uploaded_by_id])
}

model invitations {
  invitation_id                              Int              @id @default(autoincrement())
  sender_id                                  Int
  receiver_id                                Int
  message                                    String?
  status                                     InvitationStatus @default(pending)
  type                                       InvitationType   @default(group_invite)
  createdAt                                  DateTime         @default(now())
  updatedAt                                  DateTime
  students_invitations_receiver_idTostudents students         @relation("invitations_receiver_idTostudents", fields: [receiver_id], references: [student_id], onDelete: Cascade)
  students_invitations_sender_idTostudents   students         @relation("invitations_sender_idTostudents", fields: [sender_id], references: [student_id], onDelete: Cascade)

  @@unique([sender_id, receiver_id, type])
  @@index([receiver_id, status])
  @@index([sender_id])
}

model messages {
  message_id      Int           @id @default(autoincrement())
  conversation_id Int
  sender_id       Int
  content         String
  is_read         Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  attachment_name String?       @db.VarChar(255)
  attachment_type String?       @db.VarChar(50)
  attachment_url  String?       @db.VarChar(500)
  conversations   conversations @relation(fields: [conversation_id], references: [conversation_id], onDelete: Cascade)

  @@index([conversation_id, createdAt])
  @@index([conversation_id, is_read])
  @@index([sender_id])
}

model notification_recipients {
  id              Int           @id @default(autoincrement())
  notification_id Int
  user_id         Int
  is_read         Boolean       @default(false)
  read_at         DateTime?
  createdAt       DateTime      @default(now())
  notifications   notifications @relation(fields: [notification_id], references: [notification_id], onDelete: Cascade)

  @@unique([notification_id, user_id])
  @@index([user_id, createdAt])
  @@index([user_id, is_read])
}

model notifications {
  notification_id         Int                       @id @default(autoincrement())
  title                   String                    @db.VarChar(255)
  message                 String
  type                    NotificationType          @default(general)
  target_type             NotificationTarget
  created_by_id           Int?
  campus_id               Int
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime
  notification_recipients notification_recipients[]

  @@index([campus_id])
  @@index([createdAt])
}

model pinned_conversations {
  id              Int      @id @default(autoincrement())
  user_id         Int
  conversation_id Int
  pinnedAt        DateTime @default(now())

  @@unique([user_id, conversation_id])
}

model project_permission_requests {
  id           Int                     @id @default(autoincrement())
  project_id   Int
  requester_id Int
  owner_id     Int
  group_id     Int?
  message      String?
  status       ProjectPermissionStatus @default(pending)
  responded_at DateTime?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime

  @@unique([project_id, requester_id])
}

model projects {
  project_id         Int               @id @default(autoincrement())
  title              String            @db.VarChar(255)
  description        String
  category           String?           @db.VarChar(100)
  status             ProjectStatus     @default(in_progress)
  visibility         ProjectVisibility @default(private)
  thumbnail_url      String?           @db.VarChar(500)
  document_url       String?           @db.VarChar(500)
  repository_url     String?           @db.VarChar(500)
  demo_url           String?           @db.VarChar(500)
  created_by_id      Int
  group_id           Int?
  campus_id          Int
  createdAt          DateTime          @default(now())
  updatedAt          DateTime
  abstract_text      String?
  document_name      String?           @db.VarChar(255)
  embedding_id       String?           @db.VarChar(100)
  is_unique          Boolean           @default(false)
  similarity_score   Float?
  feasibility_report Json?

  @@index([campus_id])
  @@index([campus_id, visibility])
  @@index([created_by_id])
  @@index([group_id])
  @@index([status])
}

model students {
  student_id                                    Int           @id @default(autoincrement())
  user_id                                       Int           @unique
  roll_number                                   String        @unique @db.VarChar(50)
  batch                                         String?       @db.VarChar(20)
  campus_id                                     Int
  group_id                                      Int?
  createdAt                                     DateTime      @default(now())
  updatedAt                                     DateTime
  bio                                           String?
  github                                        String?       @db.VarChar(255)
  gpa                                           Float?
  interests                                     String?
  linkedin                                      String?       @db.VarChar(255)
  skills                                        String?
  is_group_admin                                Boolean       @default(false)
  invitations_invitations_receiver_idTostudents invitations[] @relation("invitations_receiver_idTostudents")
  invitations_invitations_sender_idTostudents   invitations[] @relation("invitations_sender_idTostudents")
  campuses                                      campuses      @relation(fields: [campus_id], references: [campus_id])
  groups                                        groups?       @relation(fields: [group_id], references: [group_id])
  users                                         users         @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([campus_id, group_id])
  @@index([campus_id])
  @@index([group_id])
}

model users {
  user_id          Int               @id @default(autoincrement())
  name             String            @db.VarChar(255)
  email            String            @unique @db.VarChar(255)
  password_hash    String            @db.VarChar(255)
  role             UserRole
  createdAt        DateTime          @default(now())
  updatedAt        DateTime
  profile_image    String?           @db.VarChar(500)
  status           UserStatus        @default(ACTIVE)
  fyp_coordinators fyp_coordinators?
  fyp_supervisors  fyp_supervisors?
  students         students?

  @@index([email, status])
}

enum GroupInvitationStatus {
  pending
  accepted
  rejected
  cancelled
}

enum IndustrialProjectRequestStatus {
  pending
  approved
  rejected
}

enum IndustrialProjectStatus {
  available
  booked
  completed
}

enum InvitationStatus {
  pending
  accepted
  rejected
  cancelled
}

enum InvitationType {
  group_invite
  collaboration
}

enum NotificationTarget {
  all_users
  all_students
  all_supervisors
  specific_users
}

enum NotificationType {
  general
  urgent
  announcement
  reminder
}

enum ProjectPermissionStatus {
  pending
  approved
  rejected
}

enum ProjectStatus {
  idea
  in_progress
  completed
  archived
  taken
}

enum ProjectVisibility {
  public
  private
}

enum UserRole {
  student
  supervisor
  coordinator
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  REMOVED
}
